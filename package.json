{
  "name": "envctl",
  "version": "0.0.0",
  "description": "Personal gh-style CLI for managing deploy configuration and atomically rotating provider secrets.",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "bin": {
    "envctl": "dist/envctl.js"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/envctl.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings 0 .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:ts": "vitest run",
    "check:file-length": "node scripts/check-file-length.mjs",
    "check:package-pins": "node scripts/check-package-pins.mjs"
  },
  "dependencies": {
    "js-yaml": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.0.0"
  }
}
